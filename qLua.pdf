<div id="pg9" style="-webkit-user-select: none;"><object width="909" height="1286" data="qLua_files/9.svg" type="image/svg+xml" id="pdf9" style="width:909px; height:1286px; -moz-transform:scale(1); z-index: 0;"></object></div>
